<Window x:Class="Shoes.Views.Product"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoes.Views"
        xmlns:conv="clr-namespace:Shoes.Classes"
        mc:Ignorable="d"
        Title="Guest" MinHeight="800" MinWidth="1200">
    <Window.Resources>
        <conv:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <!--Верхнее меню-->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Каталог"
                       VerticalAlignment="Center" FontSize="40"/>
            <TextBlock x:Name="UserName" VerticalAlignment="Center"
                       HorizontalAlignment="Right" Margin="20 30" Grid.Column="2"/>
            <Button Content="Выйти"
                    Width="150" HorizontalAlignment="Left"
                    Click="LogOutButtonClick" Height="46" VerticalAlignment="Top"/>
        </Grid>
        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--Карточка-->
                        <Border Margin="10" BorderBrush="DarkSlateGray" BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!--Фотография товара-->
                                
                                <!--Пока не работает, не знаю почему-->
                                <Border Width="160" Height="80" Margin="15 0">
                                    <Image Source="{Binding photo, Converter={StaticResource ImagePathConverter}}"/>
                                </Border>
                                <!--Основная информация-->
                                
                                <StackPanel Grid.Column="1" Orientation="Vertical">
                                    <!--Категория товара-->
                                    <TextBlock FontWeight="Bold">
                                        <Run Text="{Binding Category.nameCategory}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding nameProduct.nameProduct1}"/>
                                    </TextBlock>
                                    <!--Описание товара-->
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <!--Производитель-->
                                        <TextBlock Text="Производитель: "/>
                                        <TextBlock Text="{Binding Manufacturer.nameManufacturer}" FontWeight="DemiBold"/>

                                        <Separator Width="20px" Background="Transparent"/>
                                        <!--Поставщик-->
                                        <TextBlock Text="Поставщик: "/>
                                        <TextBlock Text="{Binding Provider.nameProvider}" FontWeight="DemiBold"/>
                                    </StackPanel>
                                    <!--Цена-->
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Цена: "/>
                                            <TextBlock Text="{Binding cost}"/>
                                            <TextBlock Text="$"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Скидка: "/>
                                            <TextBlock HorizontalAlignment="Left" Foreground="Red">
                                                <Run Text="{Binding sale}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    
                                    <!--Количество-->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding count}"/>
                                        <TextBlock Text="{Binding Unit.nameUnit}"/>
                                    </StackPanel>
                                    </StackPanel>
                                
                                <!--<Border Grid.Column="2">
                                </Border>-->
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
